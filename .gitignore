# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# 部署连接配置(含生产 IP/SSH 路径,勿提交);模板见 .deploy.env.example
.deploy.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# runtime lock from ScheduleWakeup
.claude/scheduled_tasks.lock
