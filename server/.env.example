# 发现猫 运行时配置示例。复制到仓库根目录的 .env 后填值:
#   cp server/.env.example .env
# 生产由 docker-compose.prod.yml 经 env_file 注入 go-api 容器。
# 全集与默认值以 server/internal/config/config.go 为准;此处列常用项。
# 注意:.env 已被 .gitignore 忽略,切勿提交真实密钥。

# ── 必填(生产 compose 用 ${VAR:?} 强校验,缺则拒启)─────────────────────
DB_NAME=oneclaw
DB_USER=oneclaw
DB_PASSWORD=                      # 生产务必设强密码,勿用默认 postgres
JWT_SECRET=                       # 32+ 位随机串;release 模式禁用默认 change-me

# ── 服务 / 数据库 ─────────────────────────────────────────────────────
SERVER_PORT=8080
GIN_MODE=release                  # 本地开发用 debug;生产 release(compose 已硬编码)
DB_HOST=postgres                  # compose 内网服务名;本地直跑用 localhost
DB_PORT=5432
DB_SSLMODE=disable
ADMIN_PHONES=                     # 逗号分隔,命中即 role=admin(可留空)

# ── 会话 Cookie(生产 HTTPS 同域)─────────────────────────────────────
COOKIE_NAME=oc_session
COOKIE_DOMAIN=                    # 生产填公网域名(如 .oneclaw.club);本地留空
COOKIE_SECURE=true                # 生产 true;本地 http 用 false
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── EchoTik 选品数据源(未配置则发现页走 mock)──────────────────────────
ECHOTIK_USERNAME=
ECHOTIK_PASSWORD=

# ── OpenRouter LLM(脚本 / 视频 / 复盘;未配置则 Agent 走降级)───────────
OPENROUTER_API_KEY=
OPENROUTER_REFERER=https://test.oneclaw.club

# ── fal.ai 图像 / 封面 / 虚拟试穿(未配置则出图不可用)────────────────────
FALAI_API_KEY=

# ── 腾讯云对象存储 COS(素材 / 视频转存;未配置则上传不可用)──────────────
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_COS_DOMAIN=               # 可选 CDN 域名

# ── 腾讯云短信验证码(未配置则走 mock,dev 回传 devCode)──────────────────
SMS_PROVIDER=mock                 # mock | tencent
SMS_TENCENT_SECRET_ID=
SMS_TENCENT_SECRET_KEY=
SMS_TENCENT_SDK_APP_ID=
SMS_TENCENT_SIGN_NAME=
SMS_TENCENT_TEMPLATE_ID=

# ── 代理商系统(推广返佣)────────────────────────────────────────────────
AGENCY_BONUS_CREDITS=300           # 经邀请码注册的新人一次性赠送积分(首个周期内有效)
AGENCY_DEFAULT_COMMISSION_BP=2000  # 新开通代理商默认佣金比例,万分比(2000=20%)
AGENCY_COMMISSION_ON_MOCK=false    # 仅 dev 生效:mock 支付是否也计佣(联调计佣链路时置 true)
