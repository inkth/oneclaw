// OneClaw schema — Postgres + Prisma
// Local dev: 推荐用 docker / Neon free / Supabase. 也可以临时切到 sqlite。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum Plan {
  FREE
  PRO
  TEAM
}

enum ProductStatus {
  RECOMMENDED
  EVALUATING
  ARCHIVED
}

enum VideoStyle {
  UNBOXING
  COMPARISON
  SCENE
  BEFORE_AFTER
}

enum AgentKind {
  ANALYST
  DIRECTOR
  OPERATOR
}

enum PaymentProvider {
  WECHAT
  ALIPAY
  MOCK
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
  REFUNDED
  FAILED
}

enum ShopPlatform {
  TIKTOK_SHOP
  AMAZON
  SHOPIFY
  LAZADA
  SHOPEE
  TEMU
  OTHER
}

enum ShopStatus {
  CONNECTED
  PENDING
  DISCONNECTED
  ERROR
}

enum MaterialType {
  IMAGE
  VIDEO
  AUDIO
  LOGO
  WATERMARK
  FONT
}

enum ModelKind {
  DIGITAL_HUMAN  // AI 数字人
  REAL_PERSON    // 真人合作模特
}

enum ModelGender {
  FEMALE
  MALE
  NEUTRAL
}

enum TaskStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

enum VideoProcessing {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

model User {
  id            String       @id @default(cuid())
  phone         String?      @unique // 中国大陆 11 位手机号；主要登录方式
  email         String?      @unique // 兼容旧数据，新流程不再录入
  name          String?
  image         String?
  passwordHash  String?      // 仅保留旧字段供 Prisma 历史兼容，新流程不用
  emailVerified DateTime?
  phoneVerified DateTime?    // 首次 OTP 验证通过时间
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  ownedWorkspaces Workspace[] @relation("OwnedWorkspaces")
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expires   DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expires   DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 手机号 OTP：codeHash = sha256(phone + plain)，避免相同 code 在不同 phone 间复用
model PhoneVerificationCode {
  id        String    @id @default(cuid())
  phone     String
  codeHash  String
  attempts  Int       @default(0)
  expires   DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([phone, createdAt])
  @@index([expires])
}

model Workspace {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  plan            Plan         @default(FREE)
  planExpiresAt   DateTime?    // 付费方案到期时间；过期后自动降为 FREE（查询时判断）
  ownerId         String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  owner           User         @relation("OwnedWorkspaces", fields: [ownerId], references: [id], onDelete: Cascade)
  members         Membership[]
  products        Product[]
  videos          Video[]
  tasks           AgentTask[]
  paymentOrders   PaymentOrder[]
  shops           Shop[]
  materials       Material[]
  models          ModelAsset[]
  discoverInteractions WorkspaceDiscoverInteraction[]
  creationTemplates CreationTemplate[]
}

model Membership {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        Role      @default(MEMBER)
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Product {
  id                 String        @id @default(cuid())
  workspaceId        String
  shopId             String?
  discoverProductId  String?       // 关联到 DiscoverProduct（来自 EchoTik 等数据源）
  title              String
  category           String
  emoji              String?       @default("📦")
  priceCents         Int
  costCents          Int
  marginPct          Int
  roiScore          Int
  monthlySales       Int
  trendDelta         Int           @default(0)
  status             ProductStatus @default(EVALUATING)
  note               String?       @db.Text
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  workspace          Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  shop               Shop?            @relation(fields: [shopId], references: [id], onDelete: SetNull)
  discoverProduct    DiscoverProduct? @relation(fields: [discoverProductId], references: [id], onDelete: SetNull)
  videos             Video[]

  @@unique([workspaceId, discoverProductId])  // 同 workspace 不能重复导入同一 EchoTik 商品
  @@index([workspaceId, status])
  @@index([shopId])
}

/// EchoTik / 未来其他数据源拉回的"主信息"，全局共享、跨 workspace 复用。
/// 持久化好处：① 列表快、省 API quota；② AgentTask 可以精准引用 productId；
/// ③ 重复访问/导入有据可查。
model DiscoverProduct {
  id                  String   @id @default(cuid())
  provider            String   @default("echotik")
  externalId          String   // 数据源里的原始 product_id
  region              String   // US / GB / ID / TH / VN / MY
  name                String
  categoryId          String?
  categoryL2Id        String?
  categoryL3Id        String?
  minPriceCents       Int
  maxPriceCents       Int
  avgPriceCents       Int
  commissionRate      Float    // 0..1
  totalSaleCnt        Int      @default(0)
  totalSaleGmvCents   Int      @default(0)
  totalIflCnt         Int      @default(0)
  totalVideoCnt       Int      @default(0)
  totalLiveCnt        Int      @default(0)
  coverUrls           Json?    // [{url, index}, ...] 来自 detail
  raw                 Json?    // 留一份原始行，调试用
  lastFetchedAt       DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  products            Product[]
  snapshots           DiscoverSnapshot[]
  interactions        WorkspaceDiscoverInteraction[]

  @@unique([provider, externalId, region])
  @@index([lastFetchedAt])
}

/// 排行榜缓存。一个 (provider, region, rank_type, rank_field) 组合只保留最新一条。
/// externalIds 是有序的 product_id 列表，渲染时按这个顺序去 DiscoverProduct 查。
model RanklistCacheEntry {
  id           String   @id @default(cuid())
  provider     String   @default("echotik")
  region       String
  rankType     Int      // 1=HOT / 2=RISING / 3=NEW
  rankField    Int      // 1=SALES / 2=GMV / 3=GROWTH
  date         String   // YYYY-MM-DD 实际命中的服务端日期
  externalIds  String[]
  fetchedAt    DateTime @default(now())

  @@unique([provider, region, rankType, rankField])
  @@index([fetchedAt])
}

/// 按天的 DiscoverProduct 指标快照。每天 1 行；用于趋势线、7d 增量计算。
model DiscoverSnapshot {
  id                String          @id @default(cuid())
  discoverProductId String
  dt                String          // YYYY-MM-DD
  totalSaleCnt      Int             @default(0)
  totalSaleGmvCents Int             @default(0)
  totalIflCnt       Int             @default(0)
  totalVideoCnt     Int             @default(0)
  totalLiveCnt      Int             @default(0)
  createdAt         DateTime        @default(now())

  discoverProduct   DiscoverProduct @relation(fields: [discoverProductId], references: [id], onDelete: Cascade)

  @@unique([discoverProductId, dt])
  @@index([discoverProductId, dt])
  @@index([dt])
}

/// 可复用的创作模板：保存"引擎 × 风格 × prompt × 默认挂件"组合，一键 apply 到 /app/create
model CreationTemplate {
  id                  String     @id @default(cuid())
  workspaceId         String
  name                String
  description         String?    @db.Text
  emoji               String?    @default("🎬")
  engine              String     // engine key, e.g. "kling-standard"
  durationSec         Int
  aspectRatio         String     @default("9:16")
  style               VideoStyle @default(SCENE)
  promptTemplate      String     @db.Text
  defaultProductId    String?
  defaultModelAssetId String?
  defaultMaterialIds  String[]   @default([])
  generateScript      Boolean    @default(false)
  generateCover       Boolean    @default(true)
  isFavorite          Boolean    @default(false)
  usageCount          Int        @default(0)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  workspace           Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  videos              Video[]

  @@index([workspaceId, isFavorite])
  @@index([workspaceId, usageCount])
}

/// 用户对 EchoTik 商品的互动（star、tag、note）。和导入与否解耦。
model WorkspaceDiscoverInteraction {
  id                String          @id @default(cuid())
  workspaceId       String
  discoverProductId String
  isStarred         Boolean         @default(false)
  tags              String[]        @default([])
  note              String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  discoverProduct   DiscoverProduct @relation(fields: [discoverProductId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, discoverProductId])
  @@index([workspaceId, isStarred])
}

model Shop {
  id              String       @id @default(cuid())
  workspaceId     String
  name            String
  platform        ShopPlatform
  country         String?      // ISO code: US / GB / SG ...
  status          ShopStatus   @default(PENDING)
  externalId      String?      // 平台店铺 ID
  // 缓存的核心指标（dev 模式用假数据填，接 API 后由同步任务刷新）
  totalRevenueCents Int        @default(0)
  orders          Int          @default(0)
  itemsSold       Int          @default(0)
  visitors        Int          @default(0)
  conversionRate  Float        @default(0)
  lastSyncAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  workspace       Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  products        Product[]

  @@unique([workspaceId, platform, externalId])
  @@index([workspaceId, status])
}

model Material {
  id            String       @id @default(cuid())
  workspaceId   String
  type          MaterialType
  originalName  String
  url           String       // COS / Blob CDN URL
  storageKey    String?      // 对象存储里的 key，便于将来删除原文件
  contentType   String?
  sizeBytes     Int          @default(0)
  width         Int?
  height        Int?
  durationSec   Int?
  tags          String[]     @default([])
  note          String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, type, createdAt])
}

// 名字避免和 Prisma 自身的 model 关键字冲突，故用 ModelAsset
model ModelAsset {
  id            String       @id @default(cuid())
  workspaceId   String
  name          String
  kind          ModelKind    @default(DIGITAL_HUMAN)
  gender        ModelGender  @default(NEUTRAL)
  avatarUrl     String?
  previewUrl    String?      // 试听 / 试看视频
  style         String?      // 风格描述：少女 / 商务 / 户外 ...
  description   String?      @db.Text
  externalId    String?      // 如接 HeyGen / D-ID，存它们那边的 model id
  usageCount    Int          @default(0)
  isFavorite    Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  videos        Video[]

  @@index([workspaceId, kind])
}

model Video {
  id                 String          @id @default(cuid())
  workspaceId        String
  productId          String?
  modelAssetId       String?         // 用了哪个模特/数字人
  templateId         String?         // 创建时套用的模板（null = 手动）
  title              String
  style              VideoStyle
  durationSec        Int             @default(15)
  aspectRatio        String?         @default("9:16") // 9:16 / 16:9 / 1:1
  prompt             String?         @db.Text // 用户/Director 输入的最终提示词
  thumbnail          String?
  thumbnailUrl       String?
  videoUrl           String?
  script             String?         @db.Text
  engine             String?         // 引擎 key，如 "kling-standard"
  falModel           String?         // 实际 fal 模型 id
  falRequestId       String?
  referenceMaterialIds String[]      @default([]) // 用户传入的参考素材
  costCents          Int             @default(0)  // 该条视频估算成本
  processing         VideoProcessing @default(COMPLETED)
  errorMessage       String?         @db.Text
  views              Int             @default(0)
  likes              Int             @default(0)
  saves              Int             @default(0)
  revenueCents       Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  workspace          Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  product            Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  modelAsset         ModelAsset?        @relation(fields: [modelAssetId], references: [id], onDelete: SetNull)
  template           CreationTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([processing])
  @@index([modelAssetId])
  @@index([templateId])
}

model AgentTask {
  id            String     @id @default(cuid())
  workspaceId   String
  agent         AgentKind
  status        TaskStatus @default(QUEUED)
  input         String     @db.Text
  output        String?    @db.Text
  metadata      Json?      // 结构化输出（如 analyst 的 products list）
  model         String?    // 调用的 LLM 模型 id
  tokensIn      Int?
  tokensOut     Int?
  costCents     Int?       // 估算成本
  startedAt     DateTime?
  finishedAt    DateTime?
  errorMessage  String?    @db.Text
  createdAt     DateTime   @default(now())

  workspace     Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

model NewsletterSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?  // 来源页面/banner
  createdAt DateTime @default(now())
}

model DemoRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  message   String?  @db.Text
  status    String   @default("new") // new | contacted | scheduled | closed
  createdAt DateTime @default(now())
}

model PaymentOrder {
  id              String          @id @default(cuid())
  workspaceId     String
  userId          String          // 谁发起的购买
  outTradeNo      String          @unique // 自有订单号（≤32 位），传给微信 / 支付宝
  provider        PaymentProvider
  providerOrderId String?         // 微信 transaction_id / 支付宝 trade_no
  plan            Plan            // 付费档位（FREE 不会出现）
  periodMonths    Int             // 1 / 3 / 12
  amountCents     Int             // 实付金额（人民币 分）
  status          PaymentStatus   @default(PENDING)
  qrCodeUrl       String?         // 微信 code_url 或 支付宝 qr_code
  rawResponse     Json?           // 调试用：provider 原始响应
  paidAt          DateTime?
  expiresAt       DateTime        // 二维码失效时间
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([status])
}
